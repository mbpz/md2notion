# Notion Integration Token (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Root page ID: 在 Notion 里打开父页面，Share → 添加 integration 后，URL 中的 ID
# 例如 https://notion.so/My-Workspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 中 xxxx... 即为 PAGE_ID
ROOT_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
